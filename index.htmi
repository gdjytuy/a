<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>안산시 생생맛집 스마트 지도</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Leaflet Map CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    <!-- Leaflet Map JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Pretendard:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Pretendard', sans-serif;
        }
        /* Leaflet custom popup styling */
        .leaflet-popup-content-wrapper {
            border-radius: 12px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
            border: 1px solid #e2e8f0;
            padding: 4px;
        }
        .leaflet-popup-content {
            margin: 8px 12px;
            line-height: 1.4;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-[1000] px-4 py-3 shadow-sm">
        <div class="max-w-7xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-4">
            <div class="flex items-center gap-3">
                <div class="p-2 bg-emerald-500 text-white rounded-xl shadow-md shadow-emerald-100">
                    <i data-lucide="map" class="w-6 h-6"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold tracking-tight text-slate-900 flex items-center gap-2">
                        안산시 생생맛집 <span class="text-emerald-600 font-extrabold text-sm bg-emerald-50 px-2 py-0.5 rounded-full border border-emerald-200">스마트 지도</span>
                    </h1>
                    <p class="text-xs text-slate-500">생생맛집 CSV 데이터를 올리거나 제공된 대표 맛집 리스트를 탐색해 보세요.</p>
                </div>
            </div>
            
            <!-- File Upload Area -->
            <div class="flex items-center gap-2 w-full sm:w-auto">
                <label for="csv-file" class="flex items-center justify-center gap-2 px-4 py-2 bg-slate-900 hover:bg-slate-800 text-white text-sm font-semibold rounded-xl cursor-pointer transition-all shadow-md shadow-slate-100 w-full sm:w-auto">
                    <i data-lucide="upload-cloud" class="w-4 h-4"></i>
                    <span>생생맛집 CSV 파일 업로드</span>
                </label>
                <input type="file" id="csv-file" accept=".csv" class="hidden" onchange="handleFileSelect(event)">
                <button onclick="loadSampleData()" class="px-3 py-2 bg-white hover:bg-slate-50 text-slate-600 hover:text-slate-900 border border-slate-200 rounded-xl text-sm font-medium transition-colors" title="샘플 데이터 복원">
                    <i data-lucide="rotate-ccw" class="w-4 h-4"></i>
                </button>
            </div>
        </div>
    </header>

    <!-- Main Content Grid -->
    <main class="flex-1 max-w-7xl w-full mx-auto p-4 flex flex-col lg:flex-row gap-4 h-[calc(100vh-73px)] overflow-hidden">
        
        <!-- Left Side: Controls, Filters & List -->
        <section class="w-full lg:w-[420px] flex flex-col gap-4 h-full shrink-0">
            
            <!-- Filter Box -->
            <div class="bg-white p-4 rounded-2xl border border-slate-200 shadow-sm flex flex-col gap-3">
                
                <!-- Search -->
                <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400">
                        <i data-lucide="search" class="w-4 h-4"></i>
                    </span>
                    <input type="text" id="search-input" oninput="filterRestaurants()" placeholder="식당 이름, 메뉴, 주소 등으로 검색..." class="w-full pl-9 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:bg-white transition-all">
                </div>

                <!-- Region Filter -->
                <div>
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1.5">지역구 선택</span>
                    <div class="grid grid-cols-3 gap-1.5">
                        <button onclick="setRegionFilter('전체')" id="region-all" class="region-filter-btn py-1.5 text-xs font-semibold rounded-lg bg-emerald-500 text-white shadow-sm shadow-emerald-50 border border-emerald-500 transition-all">전체</button>
                        <button onclick="setRegionFilter('단원구')" id="region-danwon" class="region-filter-btn py-1.5 text-xs font-semibold rounded-lg bg-slate-50 text-slate-600 border border-slate-200 hover:bg-slate-100 transition-all">단원구</button>
                        <button onclick="setRegionFilter('상록구')" id="region-sangnok" class="region-filter-btn py-1.5 text-xs font-semibold rounded-lg bg-slate-50 text-slate-600 border border-slate-200 hover:bg-slate-100 transition-all">상록구</button>
                    </div>
                </div>

                <!-- Category Filter -->
                <div>
                    <span class="text-xs font-bold text-slate-400 uppercase tracking-wider block mb-1.5">분류 필터</span>
                    <div class="flex flex-wrap gap-1.5" id="category-filter-container">
                        <!-- Categorires will be dynamically rendered -->
                    </div>
                </div>

                <!-- Statistics Banner -->
                <div class="flex justify-between items-center text-xs text-slate-500 bg-slate-50 px-3 py-2 rounded-lg border border-slate-100">
                    <span id="stats-total">총 0개 등록됨</span>
                    <span id="stats-filtered" class="font-semibold text-emerald-600">검색 조건 만족: 0개</span>
                </div>
            </div>

            <!-- List Container -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm flex-1 flex flex-col overflow-hidden">
                <div class="px-4 py-3 border-b border-slate-100 flex justify-between items-center shrink-0">
                    <h2 class="font-bold text-slate-900 text-sm flex items-center gap-1.5">
                        <i data-lucide="list-ordered" class="w-4 h-4 text-emerald-500"></i>
                        <span>맛집 리스트</span>
                    </h2>
                    <span class="text-xs bg-slate-100 text-slate-600 px-2 py-0.5 rounded-full font-semibold" id="list-count">0</span>
                </div>
                
                <!-- Inner Scrollable List -->
                <div class="flex-1 overflow-y-auto divide-y divide-slate-100" id="restaurant-list">
                    <!-- Cards dynamicly injected -->
                </div>
            </div>
        </section>

        <!-- Right Side: Map & Details Area -->
        <section class="flex-1 flex flex-col md:flex-row lg:flex-col xl:flex-row gap-4 h-full relative">
            
            <!-- Map Container -->
            <div class="flex-1 h-2/3 md:h-full lg:h-2/3 xl:h-full rounded-2xl border border-slate-200 shadow-sm overflow-hidden z-10 relative">
                <div id="map" class="w-full h-full"></div>
                <!-- Float Banner on Map for Instruction -->
                <div id="drag-overlay" class="absolute inset-0 bg-emerald-500/10 backdrop-blur-sm z-[2000] flex flex-col items-center justify-center border-4 border-dashed border-emerald-500 rounded-2xl pointer-events-none opacity-0 transition-opacity">
                    <div class="p-6 bg-white rounded-2xl shadow-xl flex flex-col items-center text-center gap-3 max-w-sm pointer-events-auto">
                        <div class="p-4 bg-emerald-50 rounded-full text-emerald-600 animate-bounce">
                            <i data-lucide="file-spreadsheet" class="w-10 h-10"></i>
                        </div>
                        <h3 class="font-bold text-slate-950 text-lg">여기에 CSV 파일을 놓아주세요</h3>
                        <p class="text-xs text-slate-500 leading-relaxed">안산시 생생맛집 공공데이터 CSV 파일을 이곳에 드롭하면 지도상에 위치를 즉시 매핑합니다.</p>
                    </div>
                </div>
            </div>

            <!-- Detail Info Card Panel -->
            <div id="detail-panel" class="w-full md:w-[360px] lg:w-full xl:w-[400px] bg-white rounded-2xl border border-slate-200 shadow-sm flex flex-col overflow-hidden h-1/3 md:h-full lg:h-1/3 xl:h-full transition-transform duration-300">
                <!-- If empty selection -->
                <div id="detail-empty" class="flex-1 flex flex-col items-center justify-center p-8 text-center gap-3">
                    <div class="p-4 bg-slate-50 text-slate-400 rounded-full">
                        <i data-lucide="map-pin" class="w-8 h-8"></i>
                    </div>
                    <h3 class="font-bold text-slate-800">선택된 식당이 없습니다</h3>
                    <p class="text-xs text-slate-500 max-w-[240px]">지도 위의 맛집 핀을 클릭하거나 왼쪽 리스트에서 식당을 선택하여 맛있는 정보를 자세히 알아보세요!</p>
                </div>

                <!-- If active selection -->
                <div id="detail-content" class="hidden flex-col h-full overflow-y-auto">
                    <!-- Top Cover & Name -->
                    <div class="p-5 border-b border-slate-100 bg-gradient-to-r from-emerald-50 to-teal-50 relative shrink-0">
                        <div class="flex justify-between items-start gap-2 mb-2">
                            <div class="flex flex-wrap gap-1">
                                <span id="detail-badge-region" class="text-[10px] font-bold px-2 py-0.5 bg-slate-900 text-white rounded-full">상록구</span>
                                <span id="detail-badge-category" class="text-[10px] font-bold px-2 py-0.5 bg-emerald-600 text-white rounded-full">한식</span>
                            </div>
                            <button onclick="closeDetails()" class="p-1 hover:bg-slate-200 rounded-lg text-slate-400 hover:text-slate-700 transition-colors">
                                <i data-lucide="x" class="w-5 h-5"></i>
                            </button>
                        </div>
                        <h2 id="detail-name" class="text-xl font-bold text-slate-950 mb-1 leading-tight">식당명</h2>
                        <p id="detail-summary" class="text-xs font-semibold text-emerald-700">식당 한줄 요약</p>
                    </div>

                    <!-- Details Body List -->
                    <div class="p-5 space-y-4 flex-1">
                        <!-- Description Section -->
                        <div class="bg-slate-50 p-4 rounded-xl border border-slate-100">
                            <h4 class="text-xs font-bold text-slate-400 mb-1.5 uppercase flex items-center gap-1.5">
                                <i data-lucide="sparkles" class="w-3.5 h-3.5 text-emerald-500"></i>
                                <span>식당 정보 및 매력 소개</span>
                            </h4>
                            <p id="detail-desc" class="text-xs text-slate-600 leading-relaxed break-all whitespace-pre-wrap">식당의 전체 상세 설명이 여기에 들어갑니다.</p>
                        </div>

                        <!-- Core Features List -->
                        <div class="space-y-3.5">
                            <!-- Address -->
                            <div class="flex gap-3">
                                <div class="text-emerald-600 shrink-0 mt-0.5">
                                    <i data-lucide="navigation" class="w-4 h-4"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <span class="text-[10px] font-bold text-slate-400 block">소재지 주소</span>
                                    <p id="detail-address" class="text-xs text-slate-700 font-medium break-words leading-tight">경기 안산시 ...</p>
                                    <button onclick="copyAddress()" class="mt-1 flex items-center gap-1 text-[10px] font-bold text-emerald-600 hover:text-emerald-700">
                                        <i data-lucide="copy" class="w-3 h-3"></i>
                                        <span>주소 복사하기</span>
                                    </button>
                                </div>
                            </div>

                            <!-- Phone -->
                            <div class="flex gap-3">
                                <div class="text-emerald-600 shrink-0 mt-0.5">
                                    <i data-lucide="phone" class="w-4 h-4"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <span class="text-[10px] font-bold text-slate-400 block">전화번호</span>
                                    <a id="detail-phone-link" href="#" class="text-xs text-slate-700 font-bold hover:underline">031-000-0000</a>
                                </div>
                            </div>

                            <!-- Seats -->
                            <div class="flex gap-3">
                                <div class="text-emerald-600 shrink-0 mt-0.5">
                                    <i data-lucide="armchair" class="w-4 h-4"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <span class="text-[10px] font-bold text-slate-400 block">좌석 정보</span>
                                    <p id="detail-seats" class="text-xs text-slate-700 font-medium leading-tight">100석</p>
                                </div>
                            </div>

                            <!-- Parking -->
                            <div class="flex gap-3">
                                <div class="text-emerald-600 shrink-0 mt-0.5">
                                    <i data-lucide="car" class="w-4 h-4"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <span class="text-[10px] font-bold text-slate-400 block">주차 여부</span>
                                    <p id="detail-parking" class="text-xs text-slate-700 font-medium leading-tight">주차 가능</p>
                                </div>
                            </div>

                            <!-- Holiday -->
                            <div class="flex gap-3">
                                <div class="text-emerald-600 shrink-0 mt-0.5">
                                    <i data-lucide="calendar-x" class="w-4 h-4"></i>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <span class="text-[10px] font-bold text-slate-400 block">휴무일</span>
                                    <p id="detail-holiday" class="text-xs text-slate-700 font-semibold leading-tight text-rose-600">연중 무휴</p>
                                </div>
                            </div>
                        </div>

                        <!-- Naver Search Action Button -->
                        <div class="pt-2">
                            <a id="detail-naver-btn" href="#" target="_blank" class="flex items-center justify-center gap-2 w-full py-2.5 bg-[#03C75A] hover:bg-[#02b351] text-white text-xs font-bold rounded-xl transition-colors shadow-sm">
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                                    <path d="M16.273 12.845L7.376 0H0v24h7.726V11.155L16.624 24H24V0h-7.727v12.845z"/>
                                </svg>
                                <span>네이버 지도에서 리뷰 검색하기</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Custom Floating Alert Box for User Notification -->
    <div id="toast" class="fixed bottom-5 left-1/2 transform -translate-x-1/2 bg-slate-900 text-white text-xs px-4 py-2.5 rounded-xl shadow-xl border border-slate-800 flex items-center gap-2 z-[9999] opacity-0 pointer-events-none transition-all duration-300">
        <i data-lucide="info" class="w-4 h-4 text-emerald-400"></i>
        <span id="toast-message">메시지 내용</span>
    </div>

    <script>
        // --- 1. Global State & Sample Data ---
        let rawData = [];
        let filteredData = [];
        let map = null;
        let markersGroup = null;
        let selectedRestaurant = null;

        let currentFilters = {
            search: '',
            region: '전체',
            category: '전체'
        };

        // Standard Coordinates of major neighborhoods in Ansan for reliable local plotting
        const neighborhoodCoords = {
            '고잔동': [37.316, 126.825],
            '중앙동': [37.319, 126.832],
            '초지동': [37.302, 126.815],
            '원곡동': [37.327, 126.793],
            '선부동': [37.336, 126.809],
            '와동':   [37.337, 126.825],
            '사동':   [37.298, 126.845],
            '본오동': [37.297, 126.865],
            '성포동': [37.320, 126.850],
            '월피동': [37.328, 126.853],
            '부곡동': [37.329, 126.868],
            '일동':   [37.306, 126.869],
            '이동':   [37.309, 126.855],
            '사사동': [37.308, 126.915],
            '대부북동': [37.262, 126.598],
            '대부남동': [37.228, 126.585],
            '대부동동': [37.247, 126.621],
            '대부도':   [37.255, 126.600],
            '목내동': [37.314, 126.745],
            '성곡동': [37.309, 126.755],
            '신길동': [37.333, 126.779],
            '팔곡동': [37.302, 126.895]
        };

        const defaultSampleData = [
            {
                name: "이천영양돌솥밥",
                desc: "이천영양돌솥밥은 균형 잡힌 영양 식단과 신토불이 음식을 고집스럽게 지켜온 한정식 식당이다. 손이 많이 가는 한정식을 같은 자리에서 27년간이나 운영했다는 것만 봐도 사장님의 한정식에 대한 집념과 애정이 오롯이 느껴진다.",
                summary: "건강하고 맛있는 돌솥밥 영양 한정식",
                phone: "031-408-2008",
                address: "경기도 안산시 상록구 항가울로 7",
                seats: "좌석 1층 30석, 2층 60석",
                parking: "인근 주차 가능",
                holiday: "명절 연휴",
                category: "한식",
                region: "상록구",
                coords: [37.3094, 126.8533]
            },
            {
                name: "청대문",
                desc: "일상의 피로에 지치고 무더위로 입맛을 잃었을 때 우리 입맛을 돋우는 귀한 식당입니다. 곤드레나물을 비롯해 푸릇한 자연으로 맛을 내는 건강식 밥상을 제공합니다.",
                summary: "사랑과 정성으로 빚은 곤드레나물 한 상",
                phone: "031-403-5545",
                address: "경기도 안산시 상록구 본삼로 11 빛나프라자",
                seats: "80석",
                parking: "건물 주차장 주차 가능",
                holiday: "명절 당일 휴무",
                category: "한식",
                region: "상록구",
                coords: [37.2977, 126.8631]
            },
            {
                name: "천교(원곡동)",
                desc: "중국 전통 샤브샤브 맛집이자 사천요리·동북 요리 전문식당으로 유명한 이곳은 13년째 같은 자리에서 중국 오리지널 요리를 내고 있는 자부심이 높은 맛집입니다.",
                summary: "중국 사천요리와 동북요리 전문점!",
                phone: "031-492-3689",
                address: "경기도 안산시 단원구 원곡로 23 (원곡동)",
                seats: "룸 3개(30석) / 홀 66석",
                parking: "원곡동 공영주차장 이용",
                holiday: "연중 무휴",
                category: "중식",
                region: "단원구",
                coords: [37.3273, 126.7936]
            },
            {
                name: "포크너 고잔점",
                desc: "안산 고잔동 골목을 대표하는 이탈리안 빈티지 레스토랑으로 부드러운 살치살 스테이크와 꾸덕한 명란크림 파스타, 뇨끼 등의 일품 이태리 다이닝 요리를 선보입니다.",
                summary: "안산에서 가장 완벽한 유러피안 클래식 다이닝",
                phone: "031-401-4752",
                address: "경기도 안산시 단원구 고잔로 108",
                seats: "32석",
                parking: "지하 전용 주차장 무료 주차",
                holiday: "연중무휴",
                category: "양식",
                region: "단원구",
                coords: [37.3168, 126.8302]
            },
            {
                name: "신도정육농장",
                desc: "주말이면 늘 줄을 서는 가성비 넘치는 한우 특수부위 맛집입니다. 신선하게 내어지는 생 한우와 서비스 육회가 한결같아 오랫동안 현지 주민들에게 엄청난 사랑을 받고 있습니다.",
                summary: "현지인들이 일순위로 꼽는 한우 정육식당",
                phone: "031-419-1509",
                address: "경기도 안산시 상록구 사사안길 5",
                seats: "150석 대규모",
                parking: "단독 야외 넓은 주차공간 확보",
                holiday: "매주 화요일",
                category: "한식",
                region: "상록구",
                coords: [37.3082, 126.9155]
            },
            {
                name: "시골순대",
                desc: "오랫동안 정성껏 삶은 두툼하고 쫄깃한 피의 막창순대와 잡내 하나 없이 맑고 진한 육수를 자랑하는 순대국밥 로컬 최정상 맛집입니다.",
                summary: "안산에서 막창순대 하면 무조건 첫 손가락",
                phone: "031-418-3352",
                address: "경기도 안산시 상록구 용신로 351",
                seats: "50석",
                parking: "인근 유료 공영주차장 이용",
                holiday: "매주 일요일",
                category: "한식",
                region: "상록구",
                coords: [37.2995, 126.8532]
            },
            {
                name: "정든식당",
                desc: "고소하고 매콤한 소스의 두루치기 요리가 맛있는 곳입니다. 가성비 좋은 집밥 스타일의 반찬들과 매콤 짭조름한 양념이 밥도둑을 자처합니다.",
                summary: "중독성 강한 명품 양념 돼지두루치기 백반",
                phone: "031-411-2007",
                address: "경기도 안산시 단원구 고잔2길 71",
                seats: "36석",
                parking: "주변 골목 및 주차라인",
                holiday: "매주 월요일",
                category: "한식",
                region: "단원구",
                coords: [37.3191, 126.8329]
            },
            {
                name: "엄청난회집",
                desc: "기본으로 상다리 부러지게 펼쳐지는 다채롭고 푸짐한 스키다시(기본 반찬)와 두툼하게 썰어 씹는 맛을 극대화한 신선 활어회 명소입니다.",
                summary: "가성비와 푸짐함을 겸비한 안산 회 탑티어",
                phone: "031-415-3330",
                address: "경기 안산시 상록구 조구나리1길 25-1",
                seats: "80석 (단체석 가능)",
                parking: "가게 앞 전용 주차라인",
                holiday: "연중무휴",
                category: "일식",
                region: "상록구",
                coords: [37.3040, 126.8612]
            },
            {
                name: "대부면옥",
                desc: "엄선한 밀가루로 손수 밀고 썰어 만든 자가제면 칼국수로, 국산 황태와 조개류로 맛을 낸 깔끔하고 개운한 육수가 가슴을 뻥 뚫리게 만듭니다.",
                summary: "깊은 자가제면 면발의 칼국수 전통 전문점",
                phone: "031-482-1144",
                address: "경기도 안산시 단원구 대부황금로 1432",
                seats: "100석",
                parking: "전용 광활한 주차장 완비",
                holiday: "매주 수요일",
                category: "한식",
                region: "단원구",
                coords: [37.255, 126.600]
            }
        ];

        // --- 2. Initialize App & Map ---
        window.addEventListener('load', () => {
            initMap();
            loadSampleData();
            setupDragAndDrop();
            lucide.createIcons();
        });

        function initMap() {
            // Center of Ansan-si (Near City Hall)
            map = L.map('map', {
                zoomControl: false
            }).setView([37.316, 126.830], 12);
            
            // Add zoom control to top-right
            L.control.zoom({ position: 'topright' }).addTo(map);

            // Clean Voyager Map Theme tiles
            L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
                maxZoom: 20
            }).addTo(map);

            markersGroup = L.layerGroup().addTo(map);
        }

        // --- 3. CSV Parsing & Processing Logic ---
        function parseCSVText(text) {
            let p = '', c = '', r = [];
            let q = false;
            let row = [''];
            for (let i = 0; i < text.length; i++) {
                c = text[i];
                let next = text[i+1];
                if (c === '"') {
                    if (q && next === '"') { row[row.length - 1] += '"'; i++; }
                    else { q = !q; }
                } else if (c === ',') {
                    if (q) { row[row.length - 1] += ','; }
                    else { row.push(''); }
                } else if (c === '\r' || c === '\n') {
                    if (q) { row[row.length - 1] += c; }
                    else {
                        if (c === '\r' && next === '\n') { i++; }
                        r.push(row);
                        row = [''];
                    }
                } else {
                    row[row.length - 1] += c;
                }
            }
            if (row.length > 1 || row[0] !== '') {
                r.push(row);
            }
            return r;
        }

        function processCSVData(csvText) {
            try {
                const parsed = parseCSVText(csvText);
                if (parsed.length < 2) {
                    showToast("올바른 형태의 CSV 파일이 아닙니다.");
                    return;
                }

                const headers = parsed[0].map(h => h.trim().replace(/"/g, ''));
                
                // Column indices lookup
                const nameIdx = headers.indexOf('식당이름');
                const descIdx = headers.indexOf('식당설명');
                const summaryIdx = headers.indexOf('식당설명요약');
                const telIdx = headers.indexOf('전화번호');
                const addrIdx = headers.indexOf('소재지주소');
                const seatIdx = headers.indexOf('좌석');
                const parkIdx = headers.indexOf('주차');
                const holidayIdx = headers.indexOf('휴무일');
                const typeIdx = headers.indexOf('분류');

                if (nameIdx === -1 || addrIdx === -1) {
                    showToast("'식당이름'과 '소재지주소' 컬럼이 필수적으로 필요합니다.");
                    return;
                }

                const processed = [];
                for (let i = 1; i < parsed.length; i++) {
                    const row = parsed[i];
                    if (row.length <= Math.max(nameIdx, addrIdx)) continue;

                    const name = row[nameIdx]?.trim().replace(/"/g, '') || '';
                    if (!name) continue;

                    const address = row[addrIdx]?.trim().replace(/"/g, '') || '';
                    
                    // Determine region (구)
                    let region = '기타';
                    if (address.includes('단원구')) region = '단원구';
                    else if (address.includes('상록구')) region = '상록구';

                    // Parse Cuisine / Category
                    let category = '기타';
                    if (typeIdx !== -1 && row[typeIdx]) {
                        category = row[typeIdx].trim().replace(/"/g, '');
                    }

                    // Clean descriptions and properties
                    const desc = descIdx !== -1 ? row[descIdx]?.trim() || '소개글이 없습니다.' : '소개글이 없습니다.';
                    const summary = summaryIdx !== -1 ? row[summaryIdx]?.trim() || '' : '';
                    const phone = telIdx !== -1 ? row[telIdx]?.trim() || '정보 없음' : '정보 없음';
                    const seats = seatIdx !== -1 ? row[seatIdx]?.trim() || '정보 없음' : '정보 없음';
                    const parking = parkIdx !== -1 ? row[parkIdx]?.trim() || '정보 없음' : '정보 없음';
                    const holiday = holidayIdx !== -1 ? row[holidayIdx]?.trim() || '정보 없음' : '정보 없음';

                    // Find Neighborhood Geocoding coords fallback
                    let coords = null;
                    for (const [dong, point] of Object.entries(neighborhoodCoords)) {
                        if (address.includes(dong) || name.includes(dong)) {
                            // Add a slight jitter (0.003 approx 300m) to prevent marker overlaps
                            const jitterLat = (Math.random() - 0.5) * 0.005;
                            const jitterLng = (Math.random() - 0.5) * 0.005;
                            coords = [point[0] + jitterLat, point[1] + jitterLng];
                            break;
                        }
                    }

                    // Default coordinates if no neighborhood matches (Near Ansan City Hall)
                    if (!coords) {
                        const jitterLat = (Math.random() - 0.5) * 0.015;
                        const jitterLng = (Math.random() - 0.5) * 0.015;
                        coords = [37.316 + jitterLat, 126.830 + jitterLng];
                    }

                    processed.push({
                        name,
                        desc,
                        summary,
                        phone,
                        address,
                        seats,
                        parking,
                        holiday,
                        category,
                        region,
                        coords
                    });
                }

                rawData = processed;
                showToast(`성공적으로 맛집 ${processed.length}곳을 불러왔습니다!`);
                
                // Reset Filters and update view
                currentFilters = { search: '', region: '전체', category: '전체' };
                document.getElementById('search-input').value = '';
                updateRegionButtonUI();
                buildCategoryFilterUI();
                filterRestaurants();
                
            } catch (error) {
                console.error(error);
                showToast("CSV 파일을 읽는 도중 오류가 발생했습니다.");
            }
        }

        // File handler
        function handleFileSelect(e) {
            const file = e.target.files[0];
            if (!file) return;
            readFile(file);
        }

        function readFile(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                processCSVData(e.target.result);
            };
            reader.readAsText(file, 'EUC-KR'); // Many Korean public CSVs use EUC-KR
        }

        // Drag and Drop implementation
        function setupDragAndDrop() {
            const dropZone = document.body;
            const overlay = document.getElementById('drag-overlay');

            window.addEventListener('dragenter', (e) => {
                e.preventDefault();
                overlay.classList.remove('opacity-0', 'pointer-events-none');
            });

            overlay.addEventListener('dragover', (e) => {
                e.preventDefault();
            });

            overlay.addEventListener('dragleave', (e) => {
                e.preventDefault();
                // Ensure it only fires when truly leaving the overlay area
                if (e.relatedTarget === null || !overlay.contains(e.relatedTarget)) {
                    overlay.classList.add('opacity-0', 'pointer-events-none');
                }
            });

            overlay.addEventListener('drop', (e) => {
                e.preventDefault();
                overlay.classList.add('opacity-0', 'pointer-events-none');
                const files = e.dataTransfer.files;
                if (files.length > 0 && files[0].name.endsWith('.csv')) {
                    readFile(files[0]);
                } else {
                    showToast("오직 .csv 확장자 파일만 업로드할 수 있습니다.");
                }
            });
        }

        // --- 4. Render & Interface Control Functions ---
        function loadSampleData() {
            rawData = JSON.parse(JSON.stringify(defaultSampleData));
            currentFilters = { search: '', region: '전체', category: '전체' };
            document.getElementById('search-input').value = '';
            
            updateRegionButtonUI();
            buildCategoryFilterUI();
            filterRestaurants();
            showToast("기본 추천 맛집 목록을 불러왔습니다.");
            closeDetails();
        }

        function buildCategoryFilterUI() {
            // Get unique categories
            const categories = ['전체', ...new Set(rawData.map(r => r.category))];
            const container = document.getElementById('category-filter-container');
            container.innerHTML = '';

            categories.forEach(cat => {
                const button = document.createElement('button');
                button.textContent = cat;
                button.id = `cat-${cat}`;
                button.onclick = () => setCategoryFilter(cat);
                
                // Style set
                button.className = `px-2.5 py-1 text-xs font-medium rounded-lg border transition-all ${
                    currentFilters.category === cat 
                    ? 'bg-emerald-600 text-white border-emerald-600 shadow-sm' 
                    : 'bg-slate-50 text-slate-600 border-slate-200 hover:bg-slate-100'
                }`;
                container.appendChild(button);
            });
        }

        function setRegionFilter(region) {
            currentFilters.region = region;
            updateRegionButtonUI();
            filterRestaurants();
        }

        function setCategoryFilter(category) {
            currentFilters.category = category;
            
            // Re-style buttons manually for faster UI feedback
            const container = document.getElementById('category-filter-container');
            container.querySelectorAll('button').forEach(btn => {
                if (btn.id === `cat-${category}`) {
                    btn.className = "px-2.5 py-1 text-xs font-medium rounded-lg border bg-emerald-600 text-white border-emerald-600 shadow-sm transition-all";
                } else {
                    btn.className = "px-2.5 py-1 text-xs font-medium rounded-lg border bg-slate-50 text-slate-600 border-slate-200 hover:bg-slate-100 transition-all";
                }
            });

            filterRestaurants();
        }

        function updateRegionButtonUI() {
            const btnAll = document.getElementById('region-all');
            const btnDanwon = document.getElementById('region-danwon');
            const btnSangnok = document.getElementById('region-sangnok');

            const activeClass = "region-filter-btn py-1.5 text-xs font-semibold rounded-lg bg-emerald-500 text-white shadow-sm shadow-emerald-50 border border-emerald-500 transition-all";
            const inactiveClass = "region-filter-btn py-1.5 text-xs font-semibold rounded-lg bg-slate-50 text-slate-600 border border-slate-200 hover:bg-slate-100 transition-all";

            btnAll.className = currentFilters.region === '전체' ? activeClass : inactiveClass;
            btnDanwon.className = currentFilters.region === '단원구' ? activeClass : inactiveClass;
            btnSangnok.className = currentFilters.region === '상록구' ? activeClass : inactiveClass;
        }

        function filterRestaurants() {
            const searchVal = document.getElementById('search-input').value.toLowerCase().trim();
            currentFilters.search = searchVal;

            filteredData = rawData.filter(item => {
                const matchSearch = !searchVal || 
                                    item.name.toLowerCase().includes(searchVal) ||
                                    item.address.toLowerCase().includes(searchVal) ||
                                    item.category.toLowerCase().includes(searchVal) ||
                                    (item.summary && item.summary.toLowerCase().includes(searchVal)) ||
                                    (item.desc && item.desc.toLowerCase().includes(searchVal));

                const matchRegion = currentFilters.region === '전체' || item.region === currentFilters.region;
                const matchCategory = currentFilters.category === '전체' || item.category === currentFilters.category;

                return matchSearch && matchRegion && matchCategory;
            });

            // Update stats
            document.getElementById('stats-total').textContent = `총 ${rawData.length}개 맛집`;
            document.getElementById('stats-filtered').textContent = `검색 만족: ${filteredData.length}개`;
            document.getElementById('list-count').textContent = filteredData.length;

            renderList();
            renderMapMarkers();
        }

        function renderList() {
            const listContainer = document.getElementById('restaurant-list');
            listContainer.innerHTML = '';

            if (filteredData.length === 0) {
                listContainer.innerHTML = `
                    <div class="p-8 text-center text-slate-400 text-xs flex flex-col items-center justify-center gap-2">
                        <i data-lucide="frown" class="w-8 h-8 text-slate-300"></i>
                        <span>해당 필터에 부합하는 식당이 없습니다.</span>
                    </div>
                `;
                lucide.createIcons();
                return;
            }

            filteredData.forEach(item => {
                const card = document.createElement('div');
                card.className = `p-4 cursor-pointer hover:bg-slate-50 transition-all border-l-4 ${
                    selectedRestaurant && selectedRestaurant.name === item.name 
                    ? 'border-emerald-500 bg-emerald-50/40' 
                    : 'border-transparent'
                }`;
                
                card.onclick = () => {
                    selectRestaurant(item);
                };

                card.innerHTML = `
                    <div class="flex justify-between items-start gap-2 mb-1.5">
                        <h3 class="font-bold text-slate-900 text-sm leading-snug">${item.name}</h3>
                        <span class="text-[10px] font-bold px-1.5 py-0.5 bg-slate-100 text-slate-600 rounded shrink-0">${item.category}</span>
                    </div>
                    <p class="text-xs text-slate-500 line-clamp-1 mb-2">${item.summary || item.desc || ''}</p>
                    <div class="flex items-center justify-between text-[11px] text-slate-400">
                        <span class="flex items-center gap-1">
                            <i data-lucide="map-pin" class="w-3 h-3 text-emerald-500"></i>
                            <span class="truncate max-w-[180px]">${item.address.replace('경기도 안산시 ', '')}</span>
                        </span>
                        <span class="font-semibold text-slate-500 shrink-0">${item.region}</span>
                    </div>
                `;

                listContainer.appendChild(card);
            });

            lucide.createIcons();
        }

        function renderMapMarkers() {
            markersGroup.clearLayers();
            if (filteredData.length === 0) return;

            const bounds = [];

            filteredData.forEach(item => {
                // Color coordination of marker
                const markerColor = item.region === '단원구' ? '#10b981' : '#3b82f6'; // Emerald vs Blue
                
                const customIcon = L.divIcon({
                    html: `
                        <div class="relative flex items-center justify-center">
                            <!-- Ping light effect -->
                            <span class="animate-ping absolute inline-flex h-6 w-6 rounded-full opacity-35" style="background-color: ${markerColor};"></span>
                            <!-- Main marker dot -->
                            <div class="w-5 h-5 rounded-full flex items-center justify-center shadow-md text-white border-2 border-white font-extrabold text-[9px]" style="background-color: ${markerColor};">
                                ${item.category.substring(0,1)}
                            </div>
                        </div>
                    `,
                    className: 'custom-marker-icon',
                    iconSize: [24, 24],
                    iconAnchor: [12, 12]
                });

                const marker = L.marker(item.coords, { icon: customIcon });
                
                // Fast mini popup setup
                marker.bindPopup(`
                    <div class="text-xs">
                        <strong class="text-slate-950 block text-sm font-bold mb-0.5">${item.name}</strong>
                        <span class="text-emerald-600 font-semibold block mb-1">${item.category} | ${item.region}</span>
                        <span class="text-slate-500 block text-[10px] break-all leading-snug">${item.address}</span>
                    </div>
                `);

                marker.on('click', () => {
                    selectRestaurant(item, false); // Focus detailed info
                });

                markersGroup.addLayer(marker);
                bounds.push(item.coords);
            });

            // Adjust view to fit all elements naturally if there's any
            if (bounds.length > 0) {
                map.fitBounds(bounds, { padding: [40, 40], maxZoom: 15 });
            }
        }

        function selectRestaurant(item, panMap = true) {
            selectedRestaurant = item;
            
            // Re-render list and cards to show selected item state
            renderList();

            // Populate Detailed Side Card
            document.getElementById('detail-empty').classList.add('hidden');
            const content = document.getElementById('detail-content');
            content.classList.remove('hidden');
            content.classList.add('flex');

            document.getElementById('detail-name').textContent = item.name;
            document.getElementById('detail-summary').textContent = item.summary || `${item.category} 전통 대표 요리집`;
            document.getElementById('detail-desc').textContent = item.desc || '제공된 식당의 설명 데이터가 존재하지 않습니다.';
            document.getElementById('detail-address').textContent = item.address;
            
            const phoneLink = document.getElementById('detail-phone-link');
            phoneLink.textContent = item.phone || '정보 없음';
            if (item.phone && item.phone !== '정보 없음') {
                phoneLink.href = `tel:${item.phone}`;
            } else {
                phoneLink.removeAttribute('href');
            }

            document.getElementById('detail-seats').textContent = item.seats || '정보 없음';
            document.getElementById('detail-parking').textContent = item.parking || '정보 없음';
            
            const holidayEl = document.getElementById('detail-holiday');
            holidayEl.textContent = item.holiday || '연중 무휴';
            if (item.holiday && item.holiday.includes('무휴')) {
                holidayEl.className = "text-xs text-emerald-600 font-semibold leading-tight";
            } else {
                holidayEl.className = "text-xs text-rose-600 font-semibold leading-tight";
            }

            // Badges
            document.getElementById('detail-badge-region').textContent = item.region;
            document.getElementById('detail-badge-category').textContent = item.category;

            // Naver Search Link
            document.getElementById('detail-naver-btn').href = `https://map.naver.com/v5/search/${encodeURIComponent('안산 ' + item.name)}`;

            if (panMap) {
                map.setView(item.coords, 16);
                
                // Find and open marker popup automatically
                markersGroup.eachLayer(marker => {
                    if (marker.getLatLng().lat === item.coords[0] && marker.getLatLng().lng === item.coords[1]) {
                        marker.openPopup();
                    }
                });
            }

            // Scroll detailed content to top
            content.scrollTop = 0;
            lucide.createIcons();
        }

        function closeDetails() {
            selectedRestaurant = null;
            document.getElementById('detail-empty').classList.remove('hidden');
            const content = document.getElementById('detail-content');
            content.classList.add('hidden');
            content.classList.remove('flex');
            renderList();
        }

        // --- 5. Helper & Utility Actions ---
        function copyAddress() {
            if (!selectedRestaurant) return;
            
            // Execute browser copy
            const tempInput = document.createElement('input');
            tempInput.value = selectedRestaurant.address;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand('copy');
            document.body.removeChild(tempInput);

            showToast("주소가 클립보드에 성공적으로 복사되었습니다!");
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toast-message').textContent = message;
            
            toast.classList.remove('opacity-0', 'pointer-events-none');
            toast.classList.add('opacity-100');

            setTimeout(() => {
                toast.classList.remove('opacity-100');
                toast.classList.add('opacity-0', 'pointer-events-none');
            }, 3000);
        }
    </script>
</body>
</html>
